# Cathedral ARKHE v28.2 — LLM Server (Axum + vLLM-compatible)
FROM rust:1.78-slim-bookworm AS builder

WORKDIR /app
COPY cathedral-llm-server/Cargo.toml cathedral-llm-server/Cargo.lock* ./
COPY cathedral-llm-server/src ./src

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*
RUN cargo build --release

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/cathedral-llm-server /usr/local/bin/

EXPOSE 8000
CMD ["cathedral-llm-server"]
