# Cathedral ARKHE v28.2 — Agent Runtime (Rust + Python bridge)
FROM rust:1.78-slim-bookworm AS builder

WORKDIR /app
COPY cathedral-agent/Cargo.toml cathedral-agent/Cargo.lock* ./
COPY cathedral-agent/src ./src
COPY cathedral-agent/config ./config

RUN apt-get update && apt-get install -y pkg-config libssl-dev python3 python3-pip && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir maturin --break-system-packages
RUN cargo build --release

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates curl python3 python3-pip && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir httpx pydantic --break-system-packages

WORKDIR /app
COPY --from=builder /app/target/release/cathedral-agent-runtime /usr/local/bin/
COPY cathedral_agent_bridge.py /opt/cathedral/
COPY wait-for-it.sh /app/
COPY entrypoint.sh /app/
RUN chmod +x /app/wait-for-it.sh /app/entrypoint.sh

EXPOSE 8001
CMD ["/app/entrypoint.sh"]
